#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_dir=$(CDPATH= cd -- "$script_dir/../.." && pwd)
export CARGO_TARGET_DIR="${XLESS_BOOTSTRAP_TARGET_DIR:-$repo_dir/.xless-bootstrap-target}"

exec cargo run --quiet --release --manifest-path "$repo_dir/Cargo.toml" -- "$@"
